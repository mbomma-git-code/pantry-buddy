{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Frontend Static Server",
      "type": "shell",
      "command": "python3",
      "args": [
        "-m",
        "http.server",
        "5500",
        "--bind",
        "127.0.0.1"
      ],
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "fileLocation": "absolute",
        "pattern": {
          "regexp": "^(.*)$",
          "file": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Serving HTTP on 127\\.0\\.0\\.1 port 5500"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      }
    }
  ]
}
